<nav class="navbar navbar-expand-lg fixed-top">
  <div class="container-fluid">

    <!-- left side -->
    <a class="navbar-brand" href="/listings">
      <i class="fa-solid fa-house"></i>
      <span>stayfinder</span>
    </a>

    <!-- desktop search bar (hidden on mobile/tablet) -->
    <form class="d-none d-lg-flex align-items-center search-bar-container mx-auto" role="search" action="/listings" method="GET">
      
      <button class="btn btn-primary rounded-circle search-btn" type="submit">
        <i class="fa-solid fa-magnifying-glass"></i>
      </button>

      <div class="search-segment">
        <input class="form-control" id="searchPlace" name="location" type="search" placeholder="Place" aria-label="Place">
      </div>
    </form>

    <!-- mobile search icon (hidden on desktop) — toggles its own collapse -->
    <button class="btn btn-primary rounded-circle search-btn-mobile d-lg-none" type="button" data-bs-toggle="collapse" data-bs-target="#mobileSearch" aria-controls="mobileSearch" aria-expanded="false" aria-label="Toggle search">
      <i class="fa-solid fa-magnifying-glass"></i>
    </button>

    <!-- hamburger — toggles user menu only -->
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup" aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- right side: user dropdown -->
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="dropdown ms-auto">
        <a class="user-dropdown dropdown-toggle" href="#" role="button" id="userMenu" data-bs-toggle="dropdown" aria-expanded="false">
          <i class="fa-regular fa-circle-user"></i>
        </a>
        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu">
          <% if(!currentUser) { %>
            <li><a class="dropdown-item" href="/signup">Signup</a></li>
            <li><a class="dropdown-item" href="/login">Login</a></li>
          <% } %>
          <% if(currentUser) { %>
            <li><a class="dropdown-item" href="/listings/new">New</a></li>
            <li><a class="dropdown-item" href="/logout">Logout</a></li>
          <% } %>
        </ul>
      </div>
    </div>

  </div>

  <!-- mobile search bar — full width, drops down below navbar when icon is tapped -->
  <div class="collapse w-100" id="mobileSearch">
    <form class="d-flex align-items-center search-bar-container mobile-search-form" role="search" action="/listings" method="GET">
      <div class="search-segment">
        <input class="form-control" id="searchPlaceMobile" name="location" type="search" placeholder="Place" aria-label="Place">
      </div>
      <button class="btn btn-primary rounded-circle search-btn" type="submit">
        <i class="fa-solid fa-magnifying-glass"></i>
      </button>
    </form>
  </div>
</nav>