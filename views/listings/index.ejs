<% layout("/layouts/boilerplate")%>

<div class="listings-page">

  <div class="container px-4">

    <!-- filter bar -->
    <div class="filters-wrapper">
      <div class="filters">
        <div class="filter active">
          <i class="fa-solid fa-fire"></i>
          <p>Trending</p>
        </div>
        <div class="filter">
          <i class="fa-solid fa-binoculars"></i>
          <p>Amazing views</p>
        </div>
        <div class="filter">
          <i class="fa-solid fa-umbrella-beach"></i>
          <p>Beach</p>
        </div>
        <div class="filter">
          <i class="fa-solid fa-mountain-city"></i>
          <p>Mountain</p>
        </div>
        <div class="filter">
          <i class="fa-solid fa-house-chimney-window"></i>
          <p>Tree house</p>
        </div>
        <div class="filter">
          <i class="fa-brands fa-fort-awesome"></i>
          <p>Castles</p>
        </div>
        <div class="filter">
          <i class="fa-solid fa-city"></i>
          <p>Top cities</p>
        </div>
      </div>

      <div class="tax-toggle">
        <div class="form-check form-switch">
          <input class="form-check-input" type="checkbox" id="flexSwitchCheckReverse">
          <label class="form-check-label" for="flexSwitchCheckReverse">Show total price</label>
        </div>
      </div>
    </div>

    <!-- listing cards -->
    <div class="row row-cols-xl-5 row-cols-lg-4 row-cols-md-3 row-cols-sm-2 row-cols-1 g-4 listing-grid">
      <% for(let list of listing) { %>
        <div class="col">
          <a href="/listings/<%= list._id %>" class="listing-card">
            <div class="listing-img-wrap">
              <img src="<%= list.image.url %>" class="listing-img" alt="<%= list.title %>">
              <button class="wishlist-btn" type="button" aria-label="Save listing">
                <i class="fa-regular fa-heart"></i>
              </button>
            </div>
            <div class="listing-body">
              <h6 class="listing-title"><%= list.title %></h6>
              <p class="listing-location"><%= list.location %></p>
              <p class="listing-price"><b>₹<%= list.price %></b> <span>per night</span></p>
            </div>
          </a>
        </div>
      <% } %>
    </div>

  </div>
</div> 
    

